{
  "rules": {
    ".read": false,
    ".write": false,

    "superAdmins": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('superAdmins').child(auth.uid).exists())",
        ".write": "auth != null && root.child('superAdmins').child(auth.uid).exists()"
      }
    },

    "userProfiles": {
      ".read": "auth != null && root.child('superAdmins').child(auth.uid).exists()",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('superAdmins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid == $uid && newData.exists() && newData.hasChildren(['uid', 'name', 'email', 'role']) && newData.child('uid').val() == $uid && newData.child('email').val() == auth.token.email && (newData.child('role').val() == 'teacher' || newData.child('role').val() == 'schoolAdmin')"
      }
    },

    "schools": {
      ".read": "auth != null && root.child('superAdmins').child(auth.uid).exists()",
      "$schoolId": {
        ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
        ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' && (!root.child('userProfiles').child(auth.uid).child('schoolId').exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == '') && !data.exists() && newData.child('admins').child(auth.uid).exists()))",

        "profile": {
          ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
          ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' && (!root.child('userProfiles').child(auth.uid).child('schoolId').exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == '') && !data.exists() && newData.parent().child('admins').child(auth.uid).exists()))"
        },

        "admins": {
          "$uid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' && (!root.child('userProfiles').child(auth.uid).child('schoolId').exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == '') && !data.parent().exists() && newData.parent().parent().child('admins').child(auth.uid).exists()))"
          }
        },

        "teachers": {
          ".read": "auth != null",
          "$tid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || (auth.token.email != null && data.child('email').val().toLowerCase() == auth.token.email.toLowerCase() && (!data.child('uid').exists() || data.child('uid').val() == auth.uid) && newData.child('uid').val() == auth.uid))"
          }
        },

        "classes": {
          "$cid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "subjects": {
          "$sid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "students": {
          "$sid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "timetables": {
          "$tid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "subjectTeachers": {
          "$stid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "holidays": {
          "$hid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "announcements": {
          "$aid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists())"
          }
        },

        "attendance": {
          "$date": {
            "$class": {
              "$period": {
                "$studentId": {
                  ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
                  ".write": "auth != null && root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId && (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' || root.child('userProfiles').child(auth.uid).child('role').val() == 'teacher')"
                }
              }
            }
          }
        },

        "attendanceMeta": {
          "$date": {
            "$class": {
              "$period": {
                ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
                ".write": "auth != null && root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId && (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' || root.child('userProfiles').child(auth.uid).child('role').val() == 'teacher')"
              }
            }
          }
        },

        "marks": {
          "$mid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId)",
            ".write": "auth != null && root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId && (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' || root.child('userProfiles').child(auth.uid).child('role').val() == 'teacher')"
          }
        },

        "teacherAlerts": {
          "$aid": {
            ".read": "auth != null && (root.child('superAdmins').child(auth.uid).exists() || root.child('schools').child($schoolId).child('admins').child(auth.uid).exists() || (root.child('userProfiles').child(auth.uid).child('role').val() == 'teacher' && root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId))",
            ".write": "auth != null && root.child('userProfiles').child(auth.uid).child('schoolId').val() == $schoolId && (root.child('userProfiles').child(auth.uid).child('role').val() == 'schoolAdmin' || root.child('userProfiles').child(auth.uid).child('role').val() == 'teacher')"
          }
        }
      }
    }
  }
}
